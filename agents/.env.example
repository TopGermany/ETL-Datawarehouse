# ============================================================
# HAIAN DWH — ETL Agent Configuration
# ============================================================
# Copy file này thành .env và điền thông tin của bạn
# KHÔNG commit file .env lên git!

# --- Google Cloud Platform ---
GCP_PROJECT_ID=haian-dwh-project
BQ_DATASET_ID=haian_dwh
GOOGLE_CREDENTIALS_PATH=/path/to/your/service-account.json

# --- Schedule ---
# Thời điểm chạy full sync hằng đêm (HH:MM định dạng 24h)
FULL_SYNC_TIME=02:00

# --- Paths ---
CSV_DATA_DIR=/path/to/Data/Raw

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=/path/to/agents/logs/etl_agent.log

# --- Email Alerting ---
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
ALERT_EMAIL=your_alert_email@gmail.com

# --- Agent Runtime ---
AGENT_MODEL=gemini-2.0-flash
AGENT_MAX_ACTIONS=8
AGENT_DEFAULT_DRY_RUN=true
